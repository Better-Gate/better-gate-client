{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Better Gate",
  "version": "0.1.0",
  "identifier": "com.bettergate.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm run dev:renderer",
    "beforeBuildCommand": "pnpm run build:renderer"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Better Gate",
        "titleBarStyle": "Overlay",
        "decorations": false,
        "width": 390,
        "height": 740,
        "minWidth": 390,
        "minHeight": 740,
        "maxWidth": 390,
        "maxHeight": 740,
        "visible": false,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https: http:; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost https: http:",
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "publisher": "Freesia Labs LLC",
    "homepage": "https://better-gate.com",
    "copyright": "Copyright © 2026 Freesia Labs LLC. All rights reserved.",
    "shortDescription": "Better Gate desktop client",
    "longDescription": "Better Gate desktop client for connecting Claude Code, Codex, Gemini CLI, and other local AI development tools.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "template": "wix/per-user-main.wxs"
      }
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQwQjc1RUExNEU1ODhBOTgKUldTWWlsaE9vVjYzUU5LT2NLaHJIQVV5RlNDb1VMcTQ3YVJrM21vQ2FQS2o3K1VyUkZYOUgxOXYK",
      "endpoints": [
        "https://github.com/Better-Gate/better-gate-client/releases/latest/download/latest.json"
      ]
    }
  }
}
